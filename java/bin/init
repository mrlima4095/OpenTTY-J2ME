#!/bin/lua

if arg[1] then
    if string.startswith(arg[1], "--serve=") then
        program = string.sub(arg[1], string.len("--serve="))
        if program == "" or not program then
            print("/bin/init: missing executable")
            os.exit(1)
        end
        print(os.request(1, "serve", os.join(program)))
    else
        print("init: " .. arg[1] .. ": not found")
    end
end

for k,v in pairs({ ["PATCH"] = "Deep Dream", ["VERSION"] = getAppProperty("MIDlet-Version"), ["RELEASE"] = "mod", ["SHELL"] = "/bin/sh" }) do os.setenv(k, v) end
for k,v in pairs({ ["TYPE"] = "platform", ["CONFIG"] = "configuration", ["PROFILE"] = "profiles", ["LOCALE"] = "locale" }) do os.setenv(k, getAppProperty("/microedition." .. v)) end

local scope, hostname = os.scope(), io.read("/etc/hostname")
local xterm = graphics.new("screen", "OpenTTY " .. getAppProperty("MIDlet-Version"))
local run = graphics.new("command", { label = "Run", type = "ok", priority = 1 })

local function label() graphics.SetLabel(io.stdin, "[" .. scope["USER"] .. "@" .. hostname .. " " .. os.getcwd() .. "]" .. (os.getuid() == 0 and "#" or "$")) end

io.mount(io.read("/etc/fstab"))
print(string.env(io.read("/etc/motd")))

os.su(java.midlet.username)
pcall(io.popen, "/home/.initrc")
label()

graphics.append(xterm, io.stdout)
graphics.append(xterm, io.stdin)
graphics.addCommand(xterm, run)
graphics.handler(xterm, {
    [run] = function(command)
        if command ~= "" then
            graphics.SetText(io.stdin, "")

            local ok, msg = pcall(os.execute, command)
            if not ok then
                print(tostring(msg))
            end
            label()
        end
    end
})
graphics.db["xterm"] = xterm
graphics.display(xterm)