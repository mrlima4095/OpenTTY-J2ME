#!/bin/lua

for k,v in pairs({ ["PATCH"] = "Deep Dream", ["VERSION"] = getAppProperty("MIDlet-Version"), ["RELEASE"] = "mod", ["SHELL"] = "/bin/sh" }) do os.setenv(k, v) end
for k,v in pairs({ ["TYPE"] = "platform", ["CONFIG"] = "configuration", ["PROFILE"] = "profiles", ["LOCALE"] = "locale" }) do os.setenv(k, getAppProperty("/microedition." .. v)) end

local scope = { PWD = "/home/", USER = java.midlet.username, ROOT = "/", ALIAS = {} }
io.mount(io.read("/etc/fstab"))

os.scope(scope)
os.su(java.midlet.username)
pcall(io.popen, "/home/.initrc")
pcall(io.popen, "/bin/xterm")
